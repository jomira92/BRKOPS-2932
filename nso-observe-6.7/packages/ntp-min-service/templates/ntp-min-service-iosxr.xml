<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$DEVICE}</name>
      <config>
        <ntp xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <max-associations>200</max-associations>
          <server>
            <server-list>
              <name>{$NTP_SERVER}</name>
              <burst/>
              <iburst/>
              <minpoll>8</minpoll>
              <maxpoll>12</maxpoll>
              <prefer/>
              <version>4</version>
            </server-list>
          </server>
          <update-calendar/>
        </ntp>
      </config>
    </device>
  </devices>
</config-template>
