<config xmlns="http://tail-f.com/ns/config/1.0">
  <aaa xmlns="http://tail-f.com/ns/aaa/1.1">
    <authentication>
      <users>
        <user>
          <name>admin</name>
          <uid>1000</uid>
          <gid>1000</gid>
          <password>$0$admin</password>
          <ssh_keydir>/tmp</ssh_keydir>
          <homedir>/tmp</homedir>
        </user>
        <user>
          <name>oper</name>
          <uid>9000</uid>
          <gid>9000</gid>
          <password>$0$oper</password>
          <ssh_keydir>/tmp</ssh_keydir>
          <homedir>/tmp</homedir>
        </user>
      </users>
    </authentication>
  </aaa>

  <nacm xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-acm">
    <groups>
      <group>
        <name>ncsadmin</name>
        <user-name>admin</user-name>
      </group>
      <group>
        <name>ncsoper</name>
        <user-name>oper</user-name>
      </group>
    </groups>
  </nacm>
</config>
