# =============================================================================
# NSO Docker Project Configuration
# =============================================================================
# Copy this file to .env before starting:  cp .env.example .env
# The .env file is gitignored and should contain your actual credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# NSO Version
# -----------------------------------------------------------------------------
# Cisco NSO image tag — change this single value for version upgrades
NSO_VERSION=6.6.1

# -----------------------------------------------------------------------------
# NSO Admin Credentials
# -----------------------------------------------------------------------------
# Created automatically by the NSO container via run-nso.sh
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# NSO Operator user — fixed in init/users.xml (password: oper, username: oper)
# Edit init/users.xml directly to change operator credentials for dev/lab use.

# -----------------------------------------------------------------------------
# NSO Northbound Interface Toggles
# -----------------------------------------------------------------------------
# These are official Cisco env vars that enable/disable NSO interfaces.
# All are disabled by default in Cisco's ncs.conf; set to "true" to enable.
NCS_CLI_SSH=true
NCS_WEBUI_TRANSPORT_TCP=true
NCS_WEBUI_TRANSPORT_SSL=true
NCS_NETCONF_TRANSPORT_SSH=true
NCS_NETCONF_TRANSPORT_TCP=false

# Host ports published by Docker for NSO interfaces
NSO_HOST_PORT_CLI_SSH=2024
NSO_HOST_PORT_WEBUI_HTTP=8080
NSO_HOST_PORT_WEBUI_HTTPS=8888
NSO_HOST_PORT_NETCONF_SSH=2022

# -----------------------------------------------------------------------------
# Netsim Configuration
# -----------------------------------------------------------------------------
# Number of simulated devices to create per NED type
NETSIM_DEVICES_PER_NED=4

# -----------------------------------------------------------------------------
# Observability — InfluxDB Configuration
# -----------------------------------------------------------------------------
# Used by the observability compose overlay (compose.observability.yaml)
INFLUXDB_ORG=nso
INFLUXDB_BUCKET=nso
INFLUXDB_ADMIN_TOKEN=nso-admin-token
INFLUXDB_USERNAME=nso
INFLUXDB_PASSWORD=nso-influx-pass

# Host ports published by Docker for observability services
GRAFANA_HOST_PORT=3000
JAEGER_HOST_PORT=16686
PROMETHEUS_HOST_PORT=9090
INFLUXDB_HOST_PORT=8086
